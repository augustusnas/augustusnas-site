---
import Base from '../layouts/Base.astro';
---
<Base title="About — Augustus Nas">
<style>
  .about-grid { display: grid; grid-template-columns: 1fr 1.6fr; border-bottom: 1px solid var(--rule); min-height: 480px; }
  .about-left { border-right: 1px solid var(--rule); padding: 48px 40px; background: var(--ink); display: flex; flex-direction: column; justify-content: space-between; }
  .about-initials { font-family: var(--serif); font-size: 72px; font-weight: 700; color: white; line-height: 1; margin-bottom: 24px; }
  .about-name { font-family: var(--serif); font-size: 20px; color: white; font-weight: 700; margin-bottom: 8px; }
  .about-role { font-size: 12px; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase; }
  .about-tagline { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.7; border-top: 1px solid rgba(255,255,255,0.12); padding-top: 24px; }
  .about-right { padding: 48px; }
  .about-eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 20px; }
  .about-headline { font-family: var(--serif); font-size: 28px; font-weight: 700; line-height: 1.2; margin-bottom: 24px; letter-spacing: -0.01em; }
  .about-body { font-size: 14px; line-height: 1.85; color: var(--mid); margin-bottom: 16px; }
  .credentials { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--rule); margin-top: 32px; }
  .cred-cell { background: var(--paper); padding: 20px; }
  .cred-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid); margin-bottom: 6px; }
  .cred-value { font-family: var(--serif); font-size: 14px; font-weight: 700; }
  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; min-height: auto; }
    .about-left { border-right: none; border-bottom: 1px solid var(--rule); padding: 36px 20px; }
    .about-initials { font-size: 52px; }
    .about-right { padding: 32px 20px; }
    .credentials { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="about-grid">
  <div class="about-left">
    <div>
      <div class="about-initials">AN</div>
      <div class="about-name">Augustus Nas</div>
      <div class="about-role">Consultant · Coach · Mentor</div>
    </div>
    <div class="about-tagline">Based in London. Working with founders and leadership teams across the UK and Europe.</div>
  </div>
  <div class="about-right">
    <div class="about-eyebrow">About me</div>
    <h1 class="about-headline">I help businesses grow without losing what makes them work</h1>
    <p class="about-body">With over a decade of experience working across start-ups, scale-ups, and established businesses, I specialise in the inflection points — those critical moments where the strategy that got you here won't get you where you're going next.</p>
    <p class="about-body">My background spans consulting, organisational design, and leadership development. I bring a systems thinker's discipline to the messy, human reality of running a business.</p>
    <p class="about-body">I work with a small number of clients at any one time — by design. Deep, sustained engagement produces better results than advisory at arm's length.</p>
    <div class="credentials">
      <div class="cred-cell">
        <div class="cred-label">Specialisms</div>
        <div class="cred-value">Strategy & Growth</div>
      </div>
      <div class="cred-cell">
        <div class="cred-label">Experience</div>
        <div class="cred-value">12+ Years</div>
      </div>
      <div class="cred-cell">
        <div class="cred-label">Location</div>
        <div class="cred-value">London, UK</div>
      </div>
      <div class="cred-cell">
        <div class="cred-label">Availability</div>
        <div class="cred-value">Limited Q3 2025</div>
      </div>
    </div>
  </div>
</div>
</Base>