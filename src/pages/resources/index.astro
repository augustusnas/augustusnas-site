---
import Base from '../../layouts/Base.astro';

const tools = [
  {
    num: '01',
    title: 'Organisational Diagnostic',
    subtitle: 'Where Transformation Stalls',
    desc: 'A structured tool for mapping the gap between stated strategy and operating reality. Identifies where incentives, decision-making, and accountability structures are producing outcomes at odds with organisational intent.',
    format: 'PDF Worksheet',
  },
  {
    num: '02',
    title: 'Leadership Readiness Assessment',
    subtitle: 'Before the Programme Starts',
    desc: 'A diagnostic for leadership teams preparing for significant change. Maps where genuine alignment exists, where it doesn\'t, and what needs to be resolved before a transformation programme can succeed.',
    format: 'PDF Worksheet',
  },
];
---
<Base title="Resources — Augustus Nas">
<style>
  .resources-header { padding: 48px 40px 32px; border-bottom: 1px solid var(--rule); }
  .resources-headline { font-family: var(--serif); font-size: 42px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
  .resources-sub { font-size: 14px; color: var(--mid); }
  .tools-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--rule); }
  .tool-card { background: var(--paper); padding: 40px; }
  .tool-num { font-family: var(--serif); font-size: 11px; color: var(--accent); margin-bottom: 20px; display: block; }
  .tool-title { font-family: var(--serif); font-size: 22px; font-weight: 700; line-height: 1.2; margin-bottom: 6px; }
  .tool-subtitle { font-family: var(--serif); font-size: 15px; font-style: italic; color: var(--mid); margin-bottom: 20px; }
  .tool-desc { font-size: 13px; line-height: 1.75; color: var(--mid); margin-bottom: 28px; }
  .tool-footer { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--rule); padding-top: 20px; }
  .tool-format { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); }
  .tool-badge { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 12px; border: 1px solid var(--rule); color: var(--mid); }
  @media (max-width: 768px) {
    .resources-header { padding: 32px 20px 24px; }
    .resources-headline { font-size: 32px; }
    .tools-grid { grid-template-columns: 1fr; }
    .tool-card { padding: 28px 20px; }
  }
</style>

<div class="resources-header">
  <h1 class="resources-headline">Diagnostic Tools</h1>
  <p class="resources-sub">Practical tools for understanding what is actually in the way.</p>
</div>

<div class="tools-grid">
  {tools.map(t => (
    <div class="tool-card">
      <span class="tool-num">{t.num}</span>
      <div class="tool-title">{t.title}</div>
      <div class="tool-subtitle">{t.subtitle}</div>
      <p class="tool-desc">{t.desc}</p>
      <div class="tool-footer">
        <span class="tool-format">{t.format}</span>
        <span class="tool-badge">Coming Soon</span>
      </div>
    </div>
  ))}
</div>
</Base>
