---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate } = Astro.props;
---
<Base title={title}>
<style>
  .post-hero { padding: 48px 40px 32px; border-bottom: 1px solid var(--rule); }
  .post-tag { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; font-weight: 500; }
  .post-title { font-family: var(--serif); font-size: clamp(28px, 4vw, 42px); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px; }
  .post-meta { font-size: 13px; color: var(--mid); }
  .post-body { max-width: 680px; margin: 0 auto; padding: 48px 40px; }
  .post-body :global(p) { font-size: 15px; line-height: 1.85; color: var(--mid); margin-bottom: 24px; }
  .post-body :global(h2) { font-family: var(--serif); font-size: 22px; font-weight: 700; margin: 40px 0 16px; color: var(--ink); }
  .post-body :global(strong) { color: var(--ink); font-weight: 500; }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 24px 24px; }
  .post-body :global(li) { font-size: 15px; line-height: 1.85; color: var(--mid); margin-bottom: 8px; }
  .post-body :global(blockquote) { border-left: 3px solid var(--accent); padding: 4px 0 4px 20px; margin: 32px 0; }
  .post-body :global(blockquote) :global(p) { font-family: var(--serif); font-size: 16px; font-style: italic; color: var(--ink); margin-bottom: 0; }
  .post-body :global(img) { max-width: 100%; height: auto; display: block; margin: 0 auto; border: 1px solid var(--rule); }
  .post-body :global(figure) { margin: 40px 0; }
  .post-body :global(figcaption) { font-size: 12px; color: var(--mid); line-height: 1.6; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--rule); }
  @media (max-width: 768px) {
    .post-hero { padding: 32px 20px 24px; }
    .post-body { padding: 32px 20px; }
  }
</style>

<div class="post-hero">
  <div class="post-title">{title}</div>
  <div class="post-meta">
    {pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
  </div>
</div>

<div class="post-body">
  <slot />
</div>
</Base>