---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate } = Astro.props;
---
<Base title={title}>
<style>
  .post-hero { padding: 48px 40px 32px; border-bottom: 1px solid var(--rule); }
  .post-tag { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; font-weight: 500; }
  .post-title { font-family: var(--serif); font-size: clamp(28px, 4vw, 42px); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px; }
  .post-meta { font-size: 13px; color: var(--mid); }
  .post-body { max-width: 680px; margin: 0 auto; padding: 48px 40px; }
  .post-body p { font-size: 15px; line-height: 1.85; color: var(--mid); margin-bottom: 24px; }
  .post-body h2 { font-family: var(--serif); font-size: 22px; font-weight: 700; margin: 40px 0 16px; color: var(--ink); }
  .post-body strong { color: var(--ink); font-weight: 500; }
  .post-body ul, .post-body ol { margin: 0 0 24px 24px; }
  .post-body li { font-size: 15px; line-height: 1.85; color: var(--mid); margin-bottom: 8px; }
</style>

<div class="post-hero">
  <div class="post-title">{title}</div>
  <div class="post-meta">
    {pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
  </div>
</div>

<div class="post-body">
  <slot />
</div>
</Base>